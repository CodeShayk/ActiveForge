<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <AssemblyName>Turquoise.ORM.PostgreSQL</AssemblyName>
    <RootNamespace>Turquoise.ORM</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>Turquoise</Authors>
    <Description>PostgreSQL provider for Turquoise ORM</Description>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>0618,1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Turquoise.ORM\Turquoise.ORM.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Npgsql" Version="8.0.3" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0.0" />
  </ItemGroup>
</Project>
